{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "internalChecksFilter": "strict",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest"
      ],
      "minimumReleaseAge": "1 day"
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "minimumReleaseAge": "7 days"
    }
  ]
}
